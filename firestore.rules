rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/registered_users/$(request.auth.token.email.toLowerCase())) &&
        get(/databases/$(database)/documents/registered_users/$(request.auth.token.email.toLowerCase())).data.role == 'Administrador';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /registered_users/{userEmail} {
      allow get: if isSignedIn() && (request.auth.token.email.toLowerCase() == userEmail.toLowerCase() || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isAdmin() || (isSignedIn() && request.auth.token.email.toLowerCase() == userEmail.toLowerCase() && !exists(/databases/$(database)/documents/registered_users/$(userEmail.toLowerCase())));
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      match /songs/{songId} {
        allow read, write: if isOwner(userId);
      }

      match /blocks/{blockId} {
        allow read, write: if isOwner(userId);
      }

      match /setlists/{setlistId} {
        allow read, write: if isOwner(userId);
      }

      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
